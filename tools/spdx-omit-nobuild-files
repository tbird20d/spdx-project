#
# Patterns for excluding files and directories
#   that are not included in a build of the kernel

# Ignore the license directory and the licensing documentation which would
# create lots of noise for no value
LICENSES/
license-rules.rst

# Ignore config files and snippets. The majority is generated
# by the Kconfig tools
kernel/configs/
arch/*/configs/

# Other files without copyrightable content
/CREDITS
/MAINTAINERS
/README

# tools and testing directories
/tools
/patches

# git management files
/.git
.gitignore

# .kunitconfig files
.kunitconfig

# stuff used for building
Makefile
Kconfig
README
.cache.mk

# some specific items
kdb_cmds
