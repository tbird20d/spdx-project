index 774abab54732..68873d370a54 100644
--- a/io_uring/io-wq.h
+++ b/io_uring/io-wq.h
@@ -1,3 +1,4 @@
+/* SPDX-License-Identifier: GPL-2.0 */
 #ifndef INTERNAL_IO_WQ_H
 #define INTERNAL_IO_WQ_H
 
